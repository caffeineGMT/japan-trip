{
  "manifest_version": 3,
  "name": "Save to Japan Trip",
  "version": "1.0.0",
  "description": "Save any place from Google Maps, TripAdvisor, or Airbnb to your Japan trip itinerary with one click",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "https://www.google.com/maps/*",
    "https://maps.google.com/*",
    "https://www.tripadvisor.com/*",
    "https://www.tripadvisor.ca/*",
    "https://www.airbnb.com/*",
    "https://www.airbnb.ca/*",
    "https://japan-trip-companion.vercel.app/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.google.com/maps/*",
        "https://maps.google.com/*"
      ],
      "js": ["content-google-maps.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.tripadvisor.com/*",
        "https://www.tripadvisor.ca/*"
      ],
      "js": ["content-tripadvisor.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.airbnb.com/*",
        "https://www.airbnb.ca/*"
      ],
      "js": ["content-airbnb.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
