{
  "$id": "https://trip-companion.app/schemas/trip-template.json",
  "title": "Trip Companion Template Schema",
  "description": "JSON Schema for validating trip companion templates with i18n support",
  "type": "object",
  "required": ["metadata", "geography", "days"],
  "properties": {
    "metadata": {
      "type": "object",
      "required": ["id", "title", "destination", "country", "duration_days"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$",
          "description": "Unique identifier for this trip template"
        },
        "title": {
          "$ref": "#/definitions/i18nString",
          "description": "Trip title in multiple languages"
        },
        "destination": {
          "$ref": "#/definitions/i18nString",
          "description": "Primary destination"
        },
        "country": {
          "type": "string",
          "description": "Country code (ISO 3166-1 alpha-2)"
        },
        "duration_days": {
          "type": "integer",
          "minimum": 1,
          "description": "Total number of days in the trip"
        },
        "season": {
          "type": "string",
          "enum": ["spring", "summer", "fall", "winter"],
          "description": "Primary season of travel"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Tags for categorization (e.g., 'cherry-blossom', 'food-tour')"
        },
        "last_updated": {
          "type": "string",
          "format": "date",
          "description": "Last update date in ISO 8601 format"
        }
      }
    },
    "geography": {
      "type": "object",
      "required": ["default_center", "default_zoom"],
      "properties": {
        "default_center": {
          "type": "array",
          "items": {
            "type": "number"
          },
          "minItems": 2,
          "maxItems": 2,
          "description": "Default map center [lat, lng]"
        },
        "default_zoom": {
          "type": "integer",
          "minimum": 1,
          "maximum": 20,
          "description": "Default map zoom level"
        }
      }
    },
    "days": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/day"
      },
      "description": "Array of trip days"
    }
  },
  "definitions": {
    "i18nString": {
      "type": "object",
      "required": ["en"],
      "properties": {
        "en": {
          "type": "string"
        },
        "zh": {
          "type": "string"
        },
        "ja": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "description": "Internationalized string with English required, Chinese and Japanese optional"
    },
    "coordinates": {
      "type": "object",
      "required": ["lat", "lng"],
      "properties": {
        "lat": {
          "type": "number",
          "minimum": -90,
          "maximum": 90
        },
        "lng": {
          "type": "number",
          "minimum": -180,
          "maximum": 180
        }
      }
    },
    "day": {
      "type": "object",
      "required": ["id", "day", "date", "weekday", "city", "theme", "color", "center", "zoom", "stops"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$"
        },
        "day": {
          "type": "string"
        },
        "date": {
          "type": "string"
        },
        "weekday": {
          "type": "string"
        },
        "city": {
          "$ref": "#/definitions/i18nString"
        },
        "theme": {
          "$ref": "#/definitions/i18nString"
        },
        "color": {
          "type": "string",
          "pattern": "^#[0-9a-fA-F]{6}$"
        },
        "center": {
          "type": "array",
          "items": {
            "type": "number"
          },
          "minItems": 2,
          "maxItems": 2
        },
        "zoom": {
          "type": "integer",
          "minimum": 1,
          "maximum": 20
        },
        "hotel": {
          "$ref": "#/definitions/i18nString"
        },
        "culturalTips": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/i18nString"
          }
        },
        "stops": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/stop"
          }
        },
        "checklist": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/i18nString"
          }
        },
        "food": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name"],
            "properties": {
              "name": {
                "$ref": "#/definitions/i18nString"
              },
              "note": {
                "$ref": "#/definitions/i18nString"
              }
            }
          }
        },
        "dinner": {
          "$ref": "#/definitions/i18nString"
        },
        "note": {
          "$ref": "#/definitions/i18nString"
        },
        "extras": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/i18nString"
          }
        }
      }
    },
    "stop": {
      "type": "object",
      "required": ["name", "time", "desc", "lat", "lng", "icon", "category"],
      "properties": {
        "name": {
          "$ref": "#/definitions/i18nString"
        },
        "time": {
          "type": "string"
        },
        "desc": {
          "$ref": "#/definitions/i18nString"
        },
        "lat": {
          "type": "number",
          "minimum": -90,
          "maximum": 90
        },
        "lng": {
          "type": "number",
          "minimum": -180,
          "maximum": 180
        },
        "icon": {
          "type": "string",
          "enum": ["food", "transport", "hotel", "activity", "attraction", "temple", "nature", "shopping", "nightlife", "flight", "train"]
        },
        "category": {
          "type": "string",
          "enum": ["food", "transport", "hotel", "activity"]
        },
        "highlight": {
          "type": "boolean"
        }
      }
    }
  }
}
