# Facebook Ads Configuration
# Copy to .env and fill in your actual credentials

# Facebook Business Manager
FB_ACCESS_TOKEN=your_facebook_access_token_here
FB_AD_ACCOUNT_ID=act_123456789
FB_PIXEL_ID=123456789012345
FB_PAGE_ID=123456789012345

# API Version
FB_API_VERSION=v18.0

# Campaign Settings
DAILY_BUDGET=50
CAMPAIGN_START_DATE=2026-03-01
CAMPAIGN_END_DATE=2026-04-30

# Targeting
TARGET_AGE_MIN=25
TARGET_AGE_MAX=45
TARGET_COUNTRIES=US,CA,GB,AU

# Conversion Tracking
CONVERSION_EVENT_LEAD=Lead
CONVERSION_EVENT_SIGNUP=CompleteRegistration
CONVERSION_EVENT_PURCHASE=Purchase

# Optimization Thresholds
MAX_CAC=50
MIN_CONVERSION_RATE=10
PAUSE_THRESHOLD_CAC=100

# Landing Page URLs
LANDING_PAGE_BASE=https://japan-trip.com
LANDING_PAGE_SIGNUP=/early-access
LANDING_PAGE_PRICING=/pricing

# UTM Parameters
UTM_SOURCE=facebook
UTM_MEDIUM_AWARENESS=carousel
UTM_MEDIUM_RETARGETING=retargeting
UTM_CAMPAIGN_AWARENESS=awareness_cherry_blossom_2026
UTM_CAMPAIGN_RETARGETING=retargeting_cherry_blossom_2026

# Discount Codes
DISCOUNT_CODE_50=COMEBACK50
DISCOUNT_CODE_60=VIP60
DISCOUNT_CODE_EARLY=EARLY50

# Reporting
REPORT_EMAIL=marketing@japan-trip.com
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Analytics
GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
MIXPANEL_TOKEN=your_mixpanel_token

# Budget Alerts
ALERT_DAILY_SPEND_THRESHOLD=75
ALERT_CAC_THRESHOLD=100
ALERT_CVR_THRESHOLD=5
