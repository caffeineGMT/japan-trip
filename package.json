{
  "name": "japan-trip",
  "version": "1.0.0",
  "description": "Multi-destination trip companion template engine with Stripe payments",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "NODE_ENV=development node server.js",
    "test": "jest",
    "test:unit": "jest tests/unit",
    "test:integration": "jest tests/integration",
    "test:e2e": "jest tests/e2e",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "test:smoke": "./tests/smoke-test.sh",
    "test:payment": "node test-payment.js",
    "validate": "node lib/validator.js",
    "astro:dev": "astro dev",
    "astro:build": "astro build",
    "astro:preview": "astro preview",
    "generate:destinations": "node scripts/generate-destination-data.js",
    "generate:seo": "node scripts/generate-seo-pages.js",
    "outreach:campaign": "node scripts/run-outreach-campaign.js",
    "outreach:followups": "node scripts/process-followups-cron.js",
    "b2b:preview": "node scripts/cold-email-sequence.js",
    "b2b:test": "node scripts/cold-email-sequence.js --test 5",
    "b2b:send": "node scripts/cold-email-sequence.js --send",
    "b2b:followup-day5": "node scripts/cold-email-sequence.js --day 5 --send",
    "b2b:followup-day10": "node scripts/cold-email-sequence.js --day 10 --send",
    "test:smoke:playwright": "./tests/run-smoke-tests.sh",
    "validate-audio": "node scripts/validate-audio.js",
    "process-audio": "node scripts/process-native-recordings.js",
    "generate-audio-tts": "python3 scripts/generate-audio-gtts.py",
    "audio-check": "npm run validate-audio",
    "next:dev": "next dev",
    "next:build": "next build",
    "next:start": "next start",
    "next:export": "next build && next export"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/caffeineGMT/japan-trip.git"
