---
interface Props {
  city: string;
  country: string;
  imageUrl?: string;
  photographer?: string;
  photographerUrl?: string;
}

const { city, country, imageUrl, photographer, photographerUrl } = Astro.props;

// Fallback to a placeholder if no image
const heroImage = imageUrl || `https://source.unsplash.com/1920x1080/?${encodeURIComponent(city)}`;
---

<div class="destination-hero">
  <div class="hero-image-container">
    <img
      src={heroImage}
      alt={`${city}, ${country}`}
      class="hero-image"
      loading="eager"
      width="1920"
      height="1080"
    />
    <div class="hero-overlay"></div>
  </div>

  <div class="hero-content">
    <h1 class="hero-title">{city} Trip Planner</h1>
    <p class="hero-subtitle">Plan Your Perfect {city} Itinerary</p>
    {photographer && photographerUrl && (
      <p class="photo-credit">
        Photo by <a href={photographerUrl} target="_blank" rel="noopener noreferrer">{photographer}</a> on Unsplash
      </p>
    )}
  </div>
</div>

<style>
  .destination-hero {
    position: relative;
    width: 100%;
    height: 70vh;
    min-height: 500px;
    max-height: 800px;
    overflow: hidden;
    margin-bottom: 3rem;
  }

  .hero-image-container {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }

  .hero-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .hero-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0.3) 0%,
      rgba(0, 0, 0, 0.5) 100%
    );
  }

  .hero-content {
    position: relative;
    z-index: 10;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    color: white;
    padding: 2rem;
  }

  .hero-title {
    font-size: clamp(2.5rem, 6vw, 5rem);
    font-weight: 800;
    margin: 0 0 1rem 0;
    text-shadow: 2px 2px 8px rgba(0, 0, 0, 0.7);
    letter-spacing: -0.02em;
  }

  .hero-subtitle {
    font-size: clamp(1.2rem, 3vw, 2rem);
    font-weight: 300;
    margin: 0 0 2rem 0;
    text-shadow: 1px 1px 4px rgba(0, 0, 0, 0.7);
  }

  .photo-credit {
    position: absolute;
    bottom: 1rem;
    right: 1rem;
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.8);
    text-shadow: 1px 1px 2px rgba(0, 0, 0, 0.7);
  }

  .photo-credit a {
    color: white;
    text-decoration: underline;
  }

  .photo-credit a:hover {
    color: #ffd700;
  }

  @media (max-width: 768px) {
    .destination-hero {
      height: 50vh;
      min-height: 400px;
    }

    .photo-credit {
      font-size: 0.65rem;
      bottom: 0.5rem;
      right: 0.5rem;
    }
  }
</style>
