---
interface Props {
  city: string;
  country: string;
  continent: string;
}

const { city, country, continent } = Astro.props;

// Mock template data - in production, filter from actual templates
const templates = [
  {
    id: 1,
    title: `${city} 3-Day Weekend Getaway`,
    description: `Perfect weekend itinerary covering ${city}'s top attractions, local food, and hidden gems.`,
    duration: '3 days',
    price: 29,
    image: `https://source.unsplash.com/400x300/?${encodeURIComponent(city + ' city')}`
  },
  {
    id: 2,
    title: `${city} Week-Long Adventure`,
    description: `Comprehensive 7-day guide with day trips, cultural experiences, and insider tips.`,
    duration: '7 days',
    price: 49,
    image: `https://source.unsplash.com/400x300/?${encodeURIComponent(city + ' travel')}`
  },
  {
    id: 3,
    title: `${city} Food & Culture Tour`,
    description: `Culinary journey through ${city}'s best restaurants, markets, and food districts.`,
    duration: '4 days',
    price: 39,
    image: `https://source.unsplash.com/400x300/?${encodeURIComponent(city + ' food')}`
  },
  {
    id: 4,
    title: `${city} on a Budget`,
    description: `Experience ${city} without breaking the bank - budget-friendly attractions and tips.`,
    duration: '5 days',
    price: 19,
    image: `https://source.unsplash.com/400x300/?${encodeURIComponent(city + ' street')}`
  },
  {
    id: 5,
    title: `Luxury ${city} Experience`,
    description: `Premium itinerary featuring ${city}'s finest hotels, restaurants, and exclusive experiences.`,
    duration: '5 days',
    price: 79,
    image: `https://source.unsplash.com/400x300/?${encodeURIComponent(city + ' luxury')}`
  }
];
---

<section class="template-showcase">
  <div class="container">
    <h2 class="section-title">Ready-Made {city} Itineraries</h2>
    <p class="section-subtitle">
      Choose from our expertly crafted trip templates and customize to your preferences
    </p>

    <div class="templates-grid">
      {templates.map((template) => (
        <article class="template-card">
          <div class="template-image">
            <img
              src={template.image}
              alt={template.title}
              loading="lazy"
              width="400"
              height="300"
            />
            <span class="template-duration">{template.duration}</span>
          </div>

          <div class="template-content">
            <h3 class="template-title">{template.title}</h3>
            <p class="template-description">{template.description}</p>

            <div class="template-footer">
              <span class="template-price">${template.price}</span>
              <a href={`/templates?destination=${city.toLowerCase()}`} class="template-cta">
                View Template
              </a>
            </div>
          </div>
        </article>
      ))}
    </div>

    <div class="browse-all">
      <a href="/templates" class="browse-all-link">
        Browse All Templates →
      </a>
    </div>
  </div>
</section>

<style>
  .template-showcase {
    padding: 4rem 0;
    background: linear-gradient(to bottom, #f8f9fa 0%, #ffffff 100%);
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .section-title {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    text-align: center;
    margin: 0 0 1rem 0;
    color: #1a1a1a;
  }

  .section-subtitle {
    font-size: 1.125rem;
    text-align: center;
    color: #666;
    margin: 0 0 3rem 0;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  .templates-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 2rem;
    margin-bottom: 3rem;
  }

  .template-card {
    background: white;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .template-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 24px rgba(0, 0, 0, 0.15);
  }

  .template-image {
    position: relative;
    width: 100%;
    height: 200px;
    overflow: hidden;
  }

  .template-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .template-card:hover .template-image img {
    transform: scale(1.05);
  }

  .template-duration {
    position: absolute;
    top: 1rem;
    right: 1rem;
    background: rgba(0, 0, 0, 0.8);
    color: white;
    padding: 0.5rem 1rem;
    border-radius: 20px;
    font-size: 0.875rem;
    font-weight: 600;
  }

  .template-content {
    padding: 1.5rem;
  }

  .template-title {
    font-size: 1.25rem;
    font-weight: 700;
    margin: 0 0 0.75rem 0;
    color: #1a1a1a;
  }

  .template-description {
    font-size: 0.95rem;
    color: #666;
    line-height: 1.6;
    margin: 0 0 1.5rem 0;
  }

  .template-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .template-price {
    font-size: 1.5rem;
    font-weight: 700;
    color: #2563eb;
  }

  .template-cta {
    background: #2563eb;
    color: white;
    padding: 0.75rem 1.5rem;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 600;
    transition: background 0.3s ease;
  }

  .template-cta:hover {
    background: #1d4ed8;
  }

  .browse-all {
    text-align: center;
  }

  .browse-all-link {
    display: inline-block;
    font-size: 1.125rem;
    font-weight: 600;
    color: #2563eb;
    text-decoration: none;
    padding: 1rem 2rem;
    border: 2px solid #2563eb;
    border-radius: 8px;
    transition: all 0.3s ease;
  }

  .browse-all-link:hover {
    background: #2563eb;
    color: white;
  }

  @media (max-width: 768px) {
    .template-showcase {
      padding: 2rem 0;
    }

    .templates-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .container {
      padding: 0 1rem;
    }
  }
</style>
